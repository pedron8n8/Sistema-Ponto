// schema.prisma

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPERADMIN
  ADMIN
  HR
  SUPERVISOR
  MEMBER
}

enum AdminPlanStatus {
  ACTIVE
  INACTIVE
}

enum EntryStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BankHoursEntryType {
  ACCRUAL
  ADJUSTMENT
  EXPIRY
}

enum BankHoursPaymentStatus {
  PENDING
  PAID
}

enum VacationStatus {
  REQUESTED
  SUPERVISOR_APPROVED
  SUPERVISOR_REJECTED
  HR_CONFIRMED
  HR_REJECTED
  CANCELED
}

model User {
  id              String        @id @default(uuid())
  email           String        @unique
  name            String?
  role            Role          @default(MEMBER)
  facialEmbedding Json?
  facialEmbeddingUpdatedAt DateTime?
  facialThreshold Float     @default(0.45)
  pinHash         String?
  pinSalt         String?
  pinUpdatedAt    DateTime?
  pinFailedAttempts Int      @default(0)
  pinLockedUntil  DateTime?
  photoPath       String?
  photoUpdatedAt  DateTime?
  contractDailyMinutes Int      @default(480)
  workdayStartTime String?
  workdayEndTime   String?
  hourlyRate       Decimal?      @db.Decimal(10, 2)
  timeZone         String        @default("America/New_York")
  bankHoursBalanceMinutes Int   @default(0)
  bankHoursLimitMinutes Int?
  bankHoursExpiryMonths Int     @default(6)
  bankHoursPolicyCode String?
  supervisorId    String?
  supervisor      User?         @relation("TeamHierarchy", fields: [supervisorId], references: [id])
  subordinates    User[]        @relation("TeamHierarchy")
  organizationAdminId String?
  organizationAdmin User?       @relation("AdminOrganization", fields: [organizationAdminId], references: [id])
  organizationMembers User[]    @relation("AdminOrganization")
  adminSeatLimit Int?
  adminExtraSeatPrice Decimal?  @db.Decimal(10, 2)
  adminPlanId      String?
  adminPlan        AdminPlan?     @relation(fields: [adminPlanId], references: [id])
  adminPlanStatus  AdminPlanStatus @default(INACTIVE)
  adminPlanLinkedAt DateTime?
  timeEntries     TimeEntry[]
  bankHoursEntries BankHoursEntry[]
  vacationRequests VacationRequest[] @relation("VacationRequester")
  supervisorVacationReviews VacationRequest[] @relation("VacationSupervisor")
  hrVacationReviews VacationRequest[] @relation("VacationHr")
  vacationLogsAsActor VacationApprovalLog[] @relation("VacationActionActor")
  reviewedLogs    ApprovalLog[] @relation("ReviewerAction")
  createdAt       DateTime      @default(now())

  @@index([email])
  @@index([role])
  @@index([supervisorId])
  @@index([organizationAdminId])
  @@index([adminPlanId])
}

model AdminPlan {
  id           String   @id @default(uuid())
  code         String   @unique
  name         String
  description  String?
  monthlyPrice Decimal  @default(0) @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  admins       User[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TimeEntry {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  clockIn     DateTime
  clockOut    DateTime?
  notes       String?
  ipAddress   String?
  location    Json?         // { lat: number, lng: number }
  device      String?
  workedMinutes Int         @default(0)
  overtimeMinutes Int       @default(0)
  overtimeMinutes50 Int     @default(0)
  overtimeMinutes100 Int    @default(0)
  overtimePercent Int       @default(0)
  bankHoursAccruedMinutes Int @default(0)
  status      EntryStatus   @default(PENDING)
  logs        ApprovalLog[]
  bankHoursEntries BankHoursEntry[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId])
  @@index([status])
  @@index([clockIn])
  @@index([userId, status])
  @@index([userId, clockIn])
}

model BankHoursEntry {
  id            String            @id @default(uuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id])
  timeEntryId   String?
  timeEntry     TimeEntry?        @relation(fields: [timeEntryId], references: [id])
  type          BankHoursEntryType
  paymentStatus BankHoursPaymentStatus @default(PENDING)
  paidAt        DateTime?
  paidById      String?
  paymentNote   String?
  minutes       Int
  description   String?
  expiresAt     DateTime?
  expiredAt     DateTime?
  createdById   String?
  createdAt     DateTime          @default(now())

  @@index([userId])
  @@index([timeEntryId])
  @@index([type])
  @@index([expiresAt])
  @@index([paymentStatus])
}

model ApprovalLog {
  id          String    @id @default(uuid())
  timeEntryId String

  @@index([timeEntryId])
  @@index([reviewerId])
  @@index([timestamp])
  timeEntry   TimeEntry @relation(fields: [timeEntryId], references: [id])
  reviewerId  String
  reviewer    User      @relation("ReviewerAction", fields: [reviewerId], references: [id])
  action      String    // ex: "APPROVED", "REJECTED", "EDIT_REQUESTED"
  comment     String?
  timestamp   DateTime  @default(now())
}

model VacationRequest {
  id                    String           @id @default(uuid())
  userId                String
  user                  User             @relation("VacationRequester", fields: [userId], references: [id])
  supervisorId          String?
  supervisor            User?            @relation("VacationSupervisor", fields: [supervisorId], references: [id])
  hrReviewerId          String?
  hrReviewer            User?            @relation("VacationHr", fields: [hrReviewerId], references: [id])
  startDate             DateTime
  endDate               DateTime
  reason                String?
  status                VacationStatus   @default(REQUESTED)
  requestedAt           DateTime         @default(now())
  supervisorReviewedAt  DateTime?
  hrReviewedAt          DateTime?
  cancelledAt           DateTime?
  logs                  VacationApprovalLog[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([userId])
  @@index([supervisorId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model VacationApprovalLog {
  id                String           @id @default(uuid())
  vacationRequestId String
  vacationRequest   VacationRequest  @relation(fields: [vacationRequestId], references: [id])
  actorId           String?
  actor             User?            @relation("VacationActionActor", fields: [actorId], references: [id])
  action            String
  comment           String?
  fromStatus        VacationStatus?
  toStatus          VacationStatus?
  timestamp         DateTime         @default(now())

  @@index([vacationRequestId])
  @@index([actorId])
  @@index([timestamp])
}