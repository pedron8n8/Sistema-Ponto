# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sistema_ponto"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sistema_ponto
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# Supabase
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your_jwt_secret_here

# Geofence
GEOFENCE_ENABLED=true
GEOFENCE_MODE=ALERT
GEOFENCE_REQUIRE_LOCATION=false
GEOFENCE_CENTER_LAT=-23.55052
GEOFENCE_CENTER_LNG=-46.63331
GEOFENCE_RADIUS_METERS=200

# Facial recognition
FACIAL_CLOCK_IN_ENABLED=true
FACIAL_REQUIRE_ENROLLMENT=false
FACIAL_MATCH_THRESHOLD_DEFAULT=0.45
FACIAL_LIVENESS_ENABLED=true
FACIAL_LIVENESS_MAX_AGE_MS=15000
FACIAL_LIVENESS_MIN_FRAMES=8
FACIAL_LIVENESS_MIN_HEAD_DELTA=0.08
FACIAL_LIVENESS_MIN_MOUTH_OPENS=1
FACIAL_LIVENESS_MIN_BLINKS=1

# PIN auth
PIN_MAX_ATTEMPTS=5
PIN_LOCK_MINUTES=15

# Overtime and bank hours
DEFAULT_DAILY_WORK_MINUTES=480
OVERTIME_HOLIDAYS=
