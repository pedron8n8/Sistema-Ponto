# Database (use the Postgres already running on the VPS)
DATABASE_URL="postgresql://postgres:CHANGE_ME@YOUR_POSTGRES_HOST:5432/sistema_ponto?schema=public"
POSTGRES_HOST=YOUR_POSTGRES_HOST
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=sistema_ponto
POSTGRES_PORT=5432

# Redis (use the Redis already running on the VPS)
REDIS_HOST=YOUR_REDIS_HOST
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# Supabase
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Server
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://seu-dominio.com
CORS_ALLOWED_ORIGINS=https://seu-dominio.com
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

# JWT
JWT_SECRET=your_jwt_secret_here

# Team invites
TEAM_INVITE_HMAC_SECRET=defina_uma_chave_forte_para_convites_de_time
TEAM_INVITE_DEFAULT_TTL_HOURS=72
TEAM_INVITE_MAX_TTL_HOURS=720

# Geofence
GEOFENCE_ENABLED=true
GEOFENCE_MODE=ALERT
GEOFENCE_REQUIRE_LOCATION=false
LOCATION_VALIDATION_SOURCE=MOBILE
GEOFENCE_CENTER_LAT=-23.55052
GEOFENCE_CENTER_LNG=-46.63331
GEOFENCE_RADIUS_METERS=200

# Facial recognition
FACIAL_CLOCK_IN_ENABLED=true
FACIAL_REQUIRE_ENROLLMENT=false
FACIAL_MATCH_THRESHOLD_DEFAULT=0.45
FACIAL_LIVENESS_ENABLED=true
FACIAL_LIVENESS_MAX_AGE_MS=15000
FACIAL_LIVENESS_MIN_FRAMES=8
FACIAL_LIVENESS_MIN_HEAD_DELTA=0.08
FACIAL_LIVENESS_MIN_MOUTH_OPENS=1
FACIAL_LIVENESS_MIN_BLINKS=1

# PIN auth
PIN_MAX_ATTEMPTS=5
PIN_LOCK_MINUTES=15

# Overtime and bank hours
DEFAULT_DAILY_WORK_MINUTES=480
OVERTIME_HOLIDAYS=

# Proactive overtime alerts (D-03)
OVERTIME_DAILY_LIMIT_MINUTES=120
OVERTIME_ALERT_THRESHOLD_PERCENT=80
OVERTIME_ALERT_CHANNELS=IN_APP
OVERTIME_ALERT_EMAIL_ENABLED=false
OVERTIME_ALERT_PUSH_ENABLED=false
PROACTIVE_ALERT_CHANNELS=EMAIL,PUSH
PROACTIVE_ALERT_SCAN_INTERVAL_MS=60000
PROACTIVE_ALERT_END_SHIFT_WINDOW_MINUTES=20
PROACTIVE_ALERT_POST_SHIFT_GRACE_MINUTES=90
PROACTIVE_DEFAULT_WORKDAY_END_TIME=18:00
PUSH_WEBHOOK_URL=
SMTP_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@systemaponto.local
NOTIFICATION_FROM_EMAIL=no-reply@systemaponto.local

# PRO public API integration
PRO_PUBLIC_API_ENABLED=true
PRO_PUBLIC_API_DEFAULT_TOKEN_TTL_HOURS=24
PRO_PUBLIC_API_MAX_TOKEN_TTL_HOURS=168
PUBLIC_API_HMAC_SECRET=defina_uma_chave_hmac_forte_com_32_chars_ou_mais

# Terminal QR dynamic auth (A-02)
TERMINAL_QR_TTL_DAYS=30
TERMINAL_QR_TTL_SECONDS=2592000
TERMINAL_QR_SINGLE_USE=false
TERMINAL_QR_SIGNING_KEY=replace_with_strong_random_key
TERMINAL_REGISTRY_JSON=[{"id":"terminal-sp-01","name":"Totem Recepcao","branch":"Matriz-SP","secret":"replace_terminal_secret"}]

# Stripe (cadeiras adicionais)
STRIPE_SECRET_KEY=
STRIPE_ADDITIONAL_SEAT_PRICE_ID=
EXTRA_ADMIN_SEAT_MONTHLY_USD=7.5
STRIPE_ADDITIONAL_SEAT_SUCCESS_URL=http://localhost:5173/app/admin/billing-result?status=success
STRIPE_ADDITIONAL_SEAT_CANCEL_URL=http://localhost:5173/app/admin/billing-result?status=cancel

# Stripe (onboarding de plano)
STRIPE_PLAN_DEFAULT_PRICE_ID=
STRIPE_PLAN_STARTER_PRICE_ID=
STRIPE_PLAN_GROWTH_PRICE_ID=
STRIPE_PLAN_PRO_PRICE_ID=
STRIPE_PLAN_CHECKOUT_MAX_SEATS=200
STRIPE_PLAN_SELECTION_SUCCESS_URL=http://localhost:5173/app/escolher-plano?status=success&session_id={CHECKOUT_SESSION_ID}
STRIPE_PLAN_SELECTION_CANCEL_URL=http://localhost:5173/app/escolher-plano?status=cancel

# Admin plans
DEFAULT_ADMIN_PLAN_CODE=STARTER
DEFAULT_ADMIN_PLAN_NAME=Starter
DEFAULT_ADMIN_PLAN_MONTHLY_PRICE=30

# Script helper credentials (dev only)
TEST_LOGIN_EMAIL=
TEST_LOGIN_PASSWORD=
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_NAME=
SEED_SUPERADMIN_EMAIL=superadmin@empresa.com
SEED_SUPERADMIN_PASSWORD=defina_uma_senha_forte
SEED_SUPERADMIN_NAME=Super Admin
SEED_RH_EMAIL=rh@empresa.com
SEED_RH_PASSWORD=defina_uma_senha_forte
SEED_RH_NAME=RH Empresa
SEED_ADMIN_EMAIL=admin@empresa.com
SEED_ADMIN_PASSWORD=defina_uma_senha_forte
SEED_SUPERVISOR1_EMAIL=supervisor1@empresa.com
SEED_SUPERVISOR1_PASSWORD=defina_uma_senha_forte
SEED_SUPERVISOR2_EMAIL=supervisor2@empresa.com
SEED_SUPERVISOR2_PASSWORD=defina_uma_senha_forte
SEED_MEMBER1_EMAIL=colaborador1@empresa.com
SEED_MEMBER1_PASSWORD=defina_uma_senha_forte
SEED_MEMBER2_EMAIL=colaborador2@empresa.com
SEED_MEMBER2_PASSWORD=defina_uma_senha_forte
