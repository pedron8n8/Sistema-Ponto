FROM node:20-slim AS builder

WORKDIR /app

ARG VITE_API_URL=https://api.omnipunt.com/api/v1
ARG VITE_SUPABASE_URL=
ARG VITE_SUPABASE_ANON_KEY=
ARG VITE_STRIPE_LINK_STARTER=
ARG VITE_STRIPE_LINK_GROWTH=
ARG VITE_STRIPE_LINK_PRO=

ENV VITE_API_URL=${VITE_API_URL}
ENV VITE_SUPABASE_URL=${VITE_SUPABASE_URL}
ENV VITE_SUPABASE_ANON_KEY=${VITE_SUPABASE_ANON_KEY}
ENV VITE_STRIPE_LINK_STARTER=${VITE_STRIPE_LINK_STARTER}
ENV VITE_STRIPE_LINK_GROWTH=${VITE_STRIPE_LINK_GROWTH}
ENV VITE_STRIPE_LINK_PRO=${VITE_STRIPE_LINK_PRO}

COPY package*.json ./
RUN npm ci

COPY . .

RUN npm run build

FROM nginx:1.27-alpine

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]